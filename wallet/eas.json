{
    "cli": {
        "version": ">= 18.0.0",
        "appVersionSource": "remote",
        "promptToConfigurePushNotifications": true,
        "requireCommit": true
    },
    "build": {
        "base": { "node": "24.12.0", "bun": "1.3.11" },
        "development": {
            "extends": "preview",
            "developmentClient": true,
            "distribution": "internal",
            "ios": { "simulator": false }
        },
        "staging": { "extends": "production", "distribution": "internal" },
        "preview": {
            "extends": "base",
            "distribution": "store",
            "autoIncrement": true,
            "env": { "NODE_ENV": "development", "STAGE": "preview" }
        },
        "production": {
            "extends": "base",
            "distribution": "store",
            "autoIncrement": true,
            "env": {
                "NODE_ENV": "production",
                "STAGE": "production",
                "EXPO_PUBLIC_PLATFORM_API_URL": "https://api.developer.privasys.org",
                "EXPO_PUBLIC_KYC_VERIFIER_APP": "privasys-identity-verifier",
                "EXPO_PUBLIC_KYC_VERIFIER_ORIGIN": "privasys-identity-verifier.apps.privasys.org",
                "EXPO_PUBLIC_KYC_VERIFIER_DIGEST": "597d5f01682ea7546bc2babeb177073ab727db2b2747ae35a34fe564921e83e5"
            }
        }
    },
    "submit": {
        "production": {
            "ios": {
                "ascAppId": "6761209489",
                "ascApiKeyId": "9H3WFH5GZY",
                "ascApiKeyIssuerId": "187e7a6e-cbee-4599-8043-eb862a5bf2f9",
                "ascApiKeyPath": "../keys/AuthKey_9H3WFH5GZY.p8"
            },
            "android": {
                "serviceAccountKeyPath": "./google-play-key.json",
                "track": "internal"
            }
        }
    }
}
