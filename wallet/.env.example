# OAuth provider client IDs (PKCE public clients — no secrets needed)
# Register apps at each provider's developer console.
# Default redirect URI: <your-scheme>://auth/callback (e.g. privasys-wallet://auth/callback)

# Google requires separate client IDs per platform (iOS vs Android OAuth client types).
# Create an "iOS" type client in Google Cloud Console. The redirect URI is derived
# automatically: com.googleusercontent.apps.<CLIENT_ID_PREFIX>:/oauthredirect
# This reversed client ID is also registered as a URL scheme in app.config.ts.
EXPO_PUBLIC_OAUTH_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_OAUTH_GOOGLE_CLIENT_ID_ANDROID=

# Microsoft (single client ID, multi-platform)
EXPO_PUBLIC_OAUTH_MICROSOFT_CLIENT_ID=

# LinkedIn and GitHub require client_secret — needs broker proxy (future)
